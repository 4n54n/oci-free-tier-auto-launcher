# ─────────────────────────────────────────────────
# OCI Free Tier Auto-Launcher — Environment Config
# ─────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets!

# ── OCI Resource OCIDs ──────────────────────────
OCI_COMPARTMENT_ID=ocid1.tenancy.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OCI_SUBNET_ID=ocid1.subnet.oc1.iad.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OCI API Authentication ───────────────────────
# These values come from your OCI config file.
# Run: oci setup config  OR fill from OCI Console → Profile → API Keys
OCI_USER_OCID=ocid1.user.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OCI_TENANCY_OCID=ocid1.tenancy.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OCI_FINGERPRINT=xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx
OCI_KEY_FILE=./oci_api_key.pem
OCI_REGION=us-ashburn-1

# ── Instance Settings ────────────────────────────
SHAPE=VM.Standard.A1.Flex
OCPUS=4
MEMORY_GB=24
OS_NAME="Canonical Ubuntu"
OS_VERSION="22.04"
POLL_SECONDS=60

# Set to true to actually launch when capacity is found
# Set to false to just monitor without launching
LAUNCH_IF_FOUND=true

# ── Telegram Notifications (optional) ───────────
# Leave blank to disable Telegram alerts
# Get your token: https://t.me/BotFather → /newbot
# Get your chat ID: https://t.me/userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
